# =============================================
# PetCare - Backend Environment Variables
# =============================================

# --- Resend (Email) ---
# Obtén tu API Key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Correo desde el que se enviarán los correos
# Por defecto usa onboarding@resend.dev, pero debes verificar tu dominio
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Frontend ---
# URL del frontend (para enlaces de activación)
# Desarrollo: http://localhost:4200
# Producción: https://tudominio.com
FRONTEND_URL=http://localhost:4200

# --- Base de Datos ---
DB_URL=jdbc:postgresql://localhost:5432/petcare?sslmode=disable
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_DDL_AUTO=update

# --- JWT ---
JWT_SECRET=ugV0Q2FyZS1EZXZlbG9wbWVudC1KMFQtU2VjcmV0
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Server ---
PORT=8090
