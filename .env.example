# =============================================
# PetCare - Backend Environment Variables
# =============================================

# --- Email ---
# Opción 1: Mailgun HTTP API (recomendado para Render/producción)
# Regístrate gratis en: https://www.mailgun.com
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.tudominio.com
# Opción 2: Gmail SMTP (solo funciona localmente, Render bloquea puertos SMTP)
# Usa una contraseña de aplicación de Gmail (https://myaccount.google.com/apppasswords)
MAIL_USERNAME=tu.correo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# Dirección de correo desde la que se envían los emails (requerida en ambos casos)
MAIL_FROM=PetCare <noreply@tudominio.com>

# --- Frontend ---
# URL del frontend (para enlaces de activación)
# Desarrollo: http://localhost:4200
# Producción: https://pabloyman-01.github.io/PetCare-Frontend
FRONTEND_URL=http://localhost:4200

# --- Base de Datos ---
DB_URL=jdbc:postgresql://localhost:5432/petcare?sslmode=disable
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_DDL_AUTO=update

# --- JWT ---
JWT_SECRET=ugV0Q2FyZS1EZXZlbG9wbWVudC1KMFQtU2VjcmV0
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Server ---
PORT=8090
