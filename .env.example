# =============================================
# PetCare - Backend Environment Variables
# =============================================

# --- Email (Gmail SMTP) ---
# Usa una contraseña de aplicación de Gmail (no tu contraseña personal)
# Crea una en: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tu.correo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=tu.correo@gmail.com

# --- Frontend ---
# URL del frontend (para enlaces de activación)
# Desarrollo: http://localhost:4200
# Producción: https://pabloyman-01.github.io/PetCare-Frontend
FRONTEND_URL=http://localhost:4200

# --- Base de Datos ---
DB_URL=jdbc:postgresql://localhost:5432/petcare?sslmode=disable
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_DDL_AUTO=update

# --- JWT ---
JWT_SECRET=ugV0Q2FyZS1EZXZlbG9wbWVudC1KMFQtU2VjcmV0
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Server ---
PORT=8090
